# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# ── Source (old Supabase project) ─────────────────────────────────────────────
# Found in: old project → Settings → API
OLD_SUPABASE_URL=https://your-old-project.supabase.co
OLD_SUPABASE_SERVICE_KEY=eyJhbGci...  # Settings → API → service_role key (not anon)

# ── Destination (production) ───────────────────────────────────────────────────
# Found in: https://supabase.com/dashboard/project/tnzzddthfmqkrvboctwj/settings/api
NEW_SUPABASE_URL=https://tnzzddthfmqkrvboctwj.supabase.co
NEW_SUPABASE_SERVICE_KEY=eyJhbGci...  # service_role key (not anon)

# ── Owner ID remapping (only needed if you used different auth accounts) ───────
# Leave both blank if you signed into both projects with the same Google/email account.
# To find your old UUID: old project → Authentication → Users → copy the UUID next to your email
# To find your new UUID: new project → Authentication → Users → copy the UUID next to your email
OLD_OWNER_ID=
NEW_OWNER_ID=
